---
interface Props {
  format?: 'banner' | 'rectangle' | 'leaderboard' | 'in-article';
  label?: string;
}

const { format = 'banner', label = 'Advertisement' } = Astro.props;
---

<div class={`ad-placeholder ad-${format}`} data-ad-demo="true">
  <div class="ad-inner">
    <div class="ad-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="3" />
        <path d="M9 15l3-6 3 6" />
        <path d="M10 13h4" />
      </svg>
    </div>
    <span class="ad-label">{label}</span>
    <span class="ad-size">
      {format === 'banner' && 'Banner Ad (728×90)'}
      {format === 'rectangle' && 'Rectangle Ad (300×250)'}
      {format === 'leaderboard' && 'Leaderboard Ad (970×90)'}
      {format === 'in-article' && 'In-Article Ad (Auto)'}
    </span>
    <span class="ad-note">Google AdSense</span>
  </div>
</div>

<style>
  .ad-placeholder {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed rgba(0, 188, 212, 0.3);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(0, 188, 212, 0.05) 0%, rgba(139, 92, 246, 0.05) 100%);
    position: relative;
    overflow: hidden;
    margin: 1.5em auto;
    box-sizing: border-box;
  }

  .ad-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(0, 188, 212, 0.03) 10px,
      rgba(0, 188, 212, 0.03) 20px
    );
  }

  .ad-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4em;
    text-align: center;
    padding: 1em;
  }

  .ad-icon {
    color: rgba(0, 188, 212, 0.6);
    margin-bottom: 0.25em;
  }

  .ad-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0, 188, 212, 0.7);
    background: rgba(0, 188, 212, 0.1);
    padding: 0.2em 0.75em;
    border-radius: 4px;
  }

  .ad-size {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'JetBrains Mono', monospace;
  }

  .ad-note {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.25);
  }

  /* Banner: typical 728x90 */
  .ad-banner {
    max-width: 728px;
    min-height: 90px;
  }

  /* Rectangle: typical 300x250 */
  .ad-rectangle {
    max-width: 300px;
    min-height: 250px;
  }

  /* Leaderboard: typical 970x90 */
  .ad-leaderboard {
    max-width: 970px;
    min-height: 90px;
  }

  /* In-article: auto-sizing */
  .ad-in-article {
    max-width: 100%;
    min-height: 120px;
  }

  @media (max-width: 768px) {
    .ad-banner,
    .ad-leaderboard {
      min-height: 60px;
    }

    .ad-size {
      font-size: 0.7rem;
    }
  }
</style>
