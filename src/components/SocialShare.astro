---
export interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

// Share URLs using standard web intents
const twitterUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const linkedinUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
---

<div class="social-share">
  <span class="share-text">Share this article:</span>
  <div class="share-buttons">
    <a href={twitterUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on X (Twitter)" class="share-button x-button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
    </a>
    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" class="share-button linkedin-button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
      </svg>
    </a>
    <a href={facebookUrl} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="share-button facebook-button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .social-share {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2rem;
    padding: 1.5rem 0;
    border-top: 1px dashed var(--border-color, #e5e5e5);
  }

  .share-text {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted, #737373);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .share-buttons {
    display: flex;
    gap: 0.75rem;
  }

  .share-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background-color: var(--bg-secondary, #f5f5f5);
    color: var(--text-primary, #171717);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    text-decoration: none;
  }

  .share-button svg {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  /* Hover Effects */
  .share-button:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.1);
  }

  .share-button:hover svg {
    transform: scale(1.1);
  }

  .x-button:hover {
    background-color: #000000;
    color: #ffffff;
  }

  .linkedin-button:hover {
    background-color: #0077b5;
    color: #ffffff;
  }

  .facebook-button:hover {
    background-color: #1877f2;
    color: #ffffff;
  }

  /* Dark mode compatibility if standard variables are used */
  :global(.dark) .share-button {
    background-color: var(--bg-secondary, #262626);
    color: var(--text-primary, #e5e5e5);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }
  
  :global(.dark) .x-button:hover {
    background-color: #ffffff;
    color: #000000;
  }
  
  :global(.dark) .social-share {
    border-top: 1px dashed var(--border-color, #404040);
  }

  @media (max-width: 640px) {
    .social-share {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
