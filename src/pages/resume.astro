---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import avatar from '../assets/avatar.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Resume | ${SITE_TITLE}`} description="Trong Dinh's Resume" />
		<link
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
			rel="stylesheet"
		/>
		<style>
			/* Layout & Container */
			.resume-main {
				background-color: var(--bg-primary);
				padding: 3rem 0;
				display: flex;
				justify-content: center;
				min-height: 100vh;
			}
			.page {
				width: 210mm;
				min-height: 297mm;
				padding: 10mm 15mm;
				background: white;
				box-sizing: border-box;
				color: #1f2937;
				font-family: "Calibri", "Carlito", "Segoe UI", sans-serif;
				box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
				position: relative;
			}

			/* Typography Reset for Resume */
			.page h1, .page h2, .page h3, .page h4, .page h5, .page h6 {
				margin: 0;
				color: #1e293b;
				font-family: inherit;
				text-transform: none;
			}
			.page p, .page li, .page span {
				color: #1f2937;
				font-family: inherit;
			}
			.page hr {
				border: 0;
				border-top: 1.5px solid #334155;
				margin: 1.5rem 0;
			}

			/* Header Section */
			.resume-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
				min-height: 140px;
			}
			.header-left {
				width: 43%;
				border-left: 10px solid #334155;
				padding-left: 1rem;
				padding-right: 0.75rem;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.header-left h1 {
				font-size: 36px;
				line-height: 1;
				font-weight: 700;
				margin-bottom: 0.25rem;
			}
			.header-left h2 {
				font-size: 17px;
				color: #2B8E92;
				font-weight: 600;
				margin-bottom: 0.625rem;
			}
			.header-left p {
				font-size: 12px;
				line-height: 1.4;
				font-weight: 400;
				text-align: justify;
				margin: 0;
			}

			.header-center {
				width: 14%;
				display: flex;
				justify-content: center;
				align-items: center;
			}
			.avatar {
				width: 110px;
				height: 110px;
				border-radius: 50%;
				border: 4px solid #81BDBF;
				object-fit: cover;
			}

			.header-right {
				width: 40%;
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				justify-content: center;
				gap: 5px;
				font-size: 10.5px;
				font-weight: 600;
				padding-right: 0.25rem;
			}
			.contact-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				white-space: nowrap;
			}
			.contact-item i {
				color: #334155;
				font-size: 0.875rem;
				width: 1rem;
				text-align: center;
			}

			/* Section Titles */
			.section-title {
				font-size: 14px;
				font-weight: 700;
				letter-spacing: 0.1em;
				margin-bottom: 0.5rem;
				margin-left: 1rem;
				text-transform: uppercase;
			}

			/* Technical Skills Grid */
			.skills-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				column-gap: 2.5rem;
				row-gap: 0.625rem;
				font-size: 10.5px;
				padding-left: 1rem;
				margin-bottom: 1.25rem;
			}
			.skill-row {
				display: flex;
				gap: 0.5rem;
			}
			.skill-key {
				width: 33.333%;
				font-weight: 700;
				flex-shrink: 0;
			}
			.skill-value {
				width: 66.666%;
				font-weight: 500;
			}

			/* Work Experience */
			.experience-container {
				display: flex;
				flex-direction: column;
				gap: 14px;
				padding-left: 1rem;
			}
			.job-entry {
				position: relative;
				padding-left: 18px;
			}
			.job-bar {
				position: absolute;
				left: 0;
				top: 4px;
				width: 12px;
				height: 32px;
				background-color: #81BDBF;
			}
			.job-title {
				font-size: 15px;
				font-weight: 700;
				margin-bottom: 2px;
			}
			.company-name {
				font-size: 13.5px;
				font-weight: 600;
				display: flex;
				align-items: center;
				gap: 4px;
				margin-bottom: 1px;
			}
			.company-name i {
				color: #54A0A2;
				font-size: 9.5px;
				position: relative;
				bottom: 4px;
			}
			.job-meta {
				display: flex;
				justify-content: space-between;
				font-size: 10.5px;
				color: #2B8E92;
				font-style: italic;
				margin-bottom: 0.25rem;
			}
			.job-desc {
				font-size: 10.5px;
				color: #6b7280;
				font-style: italic;
				margin-bottom: 0.25rem;
			}
			.achievements-label {
				font-size: 10.5px;
				color: #2B8E92;
				font-style: italic;
				margin-bottom: 2px;
			}
			.job-list {
				list-style-type: disc;
				padding-left: 1rem;
				font-size: 11px;
				font-weight: 500;
				line-height: 1.25;
				margin: 0;
			}
			.job-list li {
				margin-bottom: 3px;
			}
			.job-list li::marker {
				color: #2B8E92;
			}

			/* Tag Skills */
			.tags-container {
				display: flex;
				flex-wrap: wrap;
				gap: 7px;
				margin-left: 1rem;
				margin-top: 0.5rem;
			}
			.page .tag {
				background-color: #334155;
				color: #ffffff !important;
				font-size: 10px;
				font-weight: 600;
				padding: 5px 10px;
				border-radius: 4px;
				display: inline-block;
			}

			/* Print functionality */
			@media print {
				:global(header), :global(footer), :global(nav) {
					display: none !important;
				}
				.resume-main {
					padding: 0;
					background: white;
				}
				.page {
					box-shadow: none;
					margin: 0;
					width: 210mm;
					height: 297mm;
					padding: 10mm 15mm;
				}
			}

			/* Responsive */
			@media (max-width: 768px) {
				.resume-main {
					padding: 1rem 0;
				}
				.page {
					width: 100%;
					min-height: auto;
					padding: 1.5rem 1rem;
					box-shadow: none;
				}
				.resume-header {
					flex-direction: column;
					align-items: center;
					text-align: center;
					min-height: auto;
					gap: 1.5rem;
				}
				.header-left {
					width: 100%;
					border-left: none;
					border-top: 6px solid #334155;
					padding-left: 0;
					padding-top: 1rem;
				}
				.header-center {
					width: 100%;
					order: -1;
				}
				.header-right {
					width: 100%;
					align-items: center;
					padding-right: 0;
				}
				.skills-grid {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.skill-key {
					width: 40%;
				}
				.job-meta {
					flex-direction: column;
					gap: 2px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="resume-main">
			<div class="page shadow-2xl print:shadow-none font-medium text-[12.5px] leading-relaxed">
				<!-- HEADER -->
				<div class="resume-header">
					<!-- Left Title & Summary -->
					<div class="header-left">
						<h1>Trong Dinh</h1>
						<h2>Tech Ninja</h2>
						<p>
							Solution Architect & Engineering Leader with 16+ years in software
							and 7+ years in Web3. Passionate about open-source, I specialize in
							scalable blockchain infra, smart contracts, and leveraging
							AI/Agentic workflows to build hyper-productive teams.
						</p>
					</div>

					<!-- Center Avatar -->
					<div class="header-center">
						<img
							src={avatar.src}
							alt="Trong Dinh"
							class="avatar"
						/>
					</div>

					<!-- Right Contact Info -->
					<div class="header-right">
						<div class="contact-item">
							<span>trongdth@gmail.com</span>
							<i class="fas fa-envelope"></i>
						</div>
						<div class="contact-item">
							<span>Ho Chi Minh, Vietnam</span>
							<i class="fas fa-map-marker-alt"></i>
						</div>
						<div class="contact-item">
							<span>code4food.work</span>
							<i class="fas fa-globe"></i>
						</div>
						<div class="contact-item">
							<span>linkedin.com/in/trongdth</span>
							<i class="fab fa-linkedin"></i>
						</div>
						<div class="contact-item">
							<span>github.com/trongdth</span>
							<i class="fab fa-github"></i>
						</div>
					</div>
				</div>

				<hr />

				<!-- TECHNICAL SKILLS -->
				<section style="margin-bottom: 1.25rem;">
					<h3 class="section-title">Technical Skills</h3>
					<div class="skills-grid">
						<div class="skill-row">
							<div class="skill-key">Programming<br />Languages</div>
							<div class="skill-value">TypeScript, Python, Solidity, Rust (basic), Go, Flutter, Swift</div>
						</div>
						<div class="skill-row">
							<div class="skill-key">Blockchain &<br />Web3</div>
							<div class="skill-value">EVM, Uniswap v4 Hooks, Solidity, Hardhat, Foundry, Gas optimization, Security best practices, UUPSUpgradeable, UTXO model.</div>
						</div>
						<div class="skill-row">
							<div class="skill-key">Backend / Infra</div>
							<div class="skill-value">Node.js, FastAPI, Flask, Redis, PostgreSQL, Docker, MongoDB, Clickhouse</div>
						</div>
						<div class="skill-row">
							<div class="skill-key">DevOps / Tools</div>
							<div class="skill-value">GitHub Actions, CI/CD, Monitoring, Logging, Error tracking, Testing frameworks: Jest, Hardhat tests</div>
						</div>
						<div class="skill-row">
							<div class="skill-key">AI-Assisted<br />Development</div>
							<div class="skill-value">Local LLMs Deployment, Advanced tooling with Claude and OpenCode</div>
						</div>
						<div class="skill-row">
							<div class="skill-key">AI & Agents</div>
							<div class="skill-value">AI Agent Frameworks (OpenClaw), Skill Creator.</div>
						</div>
					</div>
				</section>

				<!-- WORK EXPERIENCE -->
				<section>
					<h3 class="section-title">Work Experience</h3>
					<div class="experience-container">
						<!-- Job 1 -->
						<div class="job-entry">
							<div class="job-bar"></div>
							<h4 class="job-title">Co-Founder / CTO Nexum Labs</h4>
							<div class="company-name">
								Nexum Labs
								<i class="fas fa-external-link-alt"></i>
							</div>
							<div class="job-meta">
								<span>06/2023 - Present</span>
								<span>Ho Chi Minh</span>
							</div>
							<div class="job-desc">A research-driven lab and technology pre-accelerator</div>
							<div class="achievements-label">Achievements/Tasks</div>
							<ul class="job-list">
								<li>Led engineering teams across Nexum Labs, managing backend, blockchain, Rust, and TypeScript teams with 17+ engineers .</li>
								<li>Pioneered the integration of AI-assisted engineering workflows.</li>
								<li>Designed and deployed autonomous AI agents utilizing the OpenClaw framework for internal automation.</li>
							</ul>
						</div>

						<!-- Job 2 -->
						<div class="job-entry">
							<div class="job-bar"></div>
							<h4 class="job-title">CTO</h4>
							<div class="company-name">
								Tokoin
								<i class="fas fa-external-link-alt"></i>
							</div>
							<div class="job-meta">
								<span>09/2019 - 06/2023</span>
								<span>Ho Chi Minh</span>
							</div>
							<div class="job-desc">Tokoin helps MSMEs use shared data to access essential funding from banks and financial institutions.</div>
							<div class="achievements-label">Achievements/Tasks</div>
							<ul class="job-list">
								<li>Design and build system architecture for Tokoin products.</li>
								<li>Work closely with CEO to build strategy map. Have a chance to work with team across SEA country.</li>
								<li>Led the development of blockchain-based identity, SME financial scoring systems, and enterprise data solutions.</li>
							</ul>
						</div>

						<!-- Job 3 -->
						<div class="job-entry">
							<div class="job-bar"></div>
							<h4 class="job-title">Tech Lead</h4>
							<div class="company-name">
								Autonomous Inc
								<i class="fas fa-external-link-alt"></i>
							</div>
							<div class="job-meta">
								<span>04/2014 - 05/2019</span>
								<span>Ho Chi Minh</span>
							</div>
							<div class="job-desc">Work smarter.</div>
							<div class="achievements-label">Achievements/Tasks</div>
							<ul class="job-list">
								<li>Led the engineering team for Personal Robot , designing system architecture and core software modules. <i class="fas fa-external-link-alt" style="font-size: 8px; color: #9ca3af; position: relative; bottom: 4px;"></i></li>
								<li>Served as the technical lead for SmartDesk , contributing to hardware-software integration and product development. <i class="fas fa-external-link-alt" style="font-size: 8px; color: #9ca3af; position: relative; bottom: 4px;"></i></li>
								<li>Worked closely with cross-functional teams to deliver high-quality consumer products at scale.</li>
							</ul>
						</div>
					</div>
				</section>

				<!-- SKILLS -->
				<section style="margin-top: 1.5rem;">
					<h3 class="section-title">Skills</h3>
					<div class="tags-container">
						<span class="tag">Team Productivity Optimization</span>
						<span class="tag">Time management</span>
						<span class="tag">Decision maker</span>
						<span class="tag">AI Agents Architecture</span>
						<span class="tag">Engineering Management</span>
						<span class="tag">Product Execution</span>
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
