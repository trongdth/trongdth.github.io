---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PomodoroApp from '../components/PomodoroApp';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_TITLE } from '../consts';
import {
	buildWebApplicationSchema,
	buildBreadcrumbSchema,
	buildFAQSchema,
} from '../lib/schema-helpers';

const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: 'Home', url: 'https://code4food.work' },
	{ name: 'Pomodoro Timer', url: 'https://code4food.work/pomodoro' },
]);

const webAppSchema = buildWebApplicationSchema();

const faqItems = [
	{
		question: 'What is the Pomodoro Technique?',
		answer: 'The Pomodoro Technique is a time management method developed by Francesco Cirillo in the late 1980s. It uses a timer to break work into focused intervals (traditionally 25 minutes), separated by short breaks. Each interval is called a "pomodoro" (Italian for tomato). After completing four pomodoros, you take a longer break of 15–30 minutes.',
	},
	{
		question: 'How long is a Pomodoro session?',
		answer: 'A standard Pomodoro session is 25 minutes of focused work followed by a 5-minute short break. After four sessions, a longer break of 15–30 minutes is recommended. However, you can customize these durations in our timer to match your personal productivity rhythm.',
	},
	{
		question: 'What are the benefits of the Pomodoro Technique?',
		answer: 'The Pomodoro Technique helps improve focus and concentration, reduces mental fatigue, increases accountability and awareness of how you spend your time, provides a structured approach to tackling large tasks, and helps combat procrastination by making work feel more manageable in short bursts.',
	},
	{
		question: 'Is this Pomodoro timer free to use?',
		answer: 'Yes, this Pomodoro timer is completely free. It runs entirely in your browser with no account needed. Your data is stored locally on your device for privacy.',
	},
];

const faqSchema = buildFAQSchema(faqItems);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Free Online Pomodoro Timer — ${SITE_TITLE}`}
			description="Free online Pomodoro timer to boost your productivity. Customizable focus intervals, task tracking, productivity analytics, and browser notifications — all in your browser, no sign-up required."
		/>
		<SchemaOrg schema={breadcrumbSchema} />
		<SchemaOrg schema={webAppSchema} />
		<SchemaOrg schema={faqSchema} />
	</head>
	<body>
		<Header />
		<main>
			<div class="pomodoro-page-header">
				<a href="/" class="back-home">← Back to Home</a>
				<h1><span class="glow-text">Pomodoro</span> Timer</h1>
				<p class="pomodoro-subtitle">Focus. Break. Repeat. Master your productivity rhythm.</p>
			</div>
			<PomodoroApp client:load />

			<!-- Desktop Client Promotion -->
			<section class="desktop-promo-section">
				<div class="promo-card">
					<div class="promo-tag">RECOMMENDED</div>
					<div class="promo-body">
						<h2>Upgrade to myOKR Desktop</h2>
						<p class="promo-desc">
							Prefer a dedicated app? The free, open-source <strong>myOKR (v0.2.0)</strong> client runs offline on macOS, Windows, and Linux. It combines this Pomodoro timer with monthly OKRs, Eisenhower matrix prioritizing, and weekly reviews.
						</p>
						<div class="promo-features">
							<div class="promo-feature">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="2" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
								<span><strong>Offline first:</strong> Local database, zero tracking, and native notifications.</span>
							</div>
							<div class="promo-feature">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feature-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
								<span><strong>Goal-linked:</strong> Automatically sync your focus session stats to key results.</span>
							</div>
						</div>
						<div class="promo-actions">
							<a href="https://github.com/trongdth/myOKR/releases/tag/v0.2.0" target="_blank" rel="noopener noreferrer" class="btn btn-glow">
								Download v0.2.0
								<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-left: 0.25em; display: inline-block; vertical-align: middle;"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"/></svg>
							</a>
							<a href="https://github.com/trongdth/myOKR" target="_blank" rel="noopener noreferrer" class="btn-secondary-link">
								Learn more on GitHub
								<svg viewBox="0 0 24 24" width="14" height="14" class="external-icon"><path fill="currentColor" d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
							</a>
						</div>
					</div>
				</div>
			</section>

			<noscript>
				<div class="noscript-message">
					<p>This Pomodoro Timer requires JavaScript to run. Please enable JavaScript in your browser to use the timer.</p>
				</div>
			</noscript>

			<!-- Learn More accordion with SEO content -->
			<section class="seo-section">
				<details class="learn-more-accordion">
					<summary class="learn-more-trigger">
						<span>Learn More About the Pomodoro Technique</span>
						<svg class="chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
					</summary>
					<div class="learn-more-content">
						<h2>What is the Pomodoro Technique?</h2>
						<p>
							The Pomodoro Technique is a proven time management method that uses timed intervals to boost focus and productivity. Developed by Francesco Cirillo, it breaks work into manageable sessions — traditionally 25 minutes of deep focus followed by a 5-minute break.
						</p>

						<h3>How to Use This Timer</h3>
						<ol>
							<li><strong>Set your task</strong> — Add a task in the Tasks tab so you know exactly what to focus on.</li>
							<li><strong>Start the timer</strong> — Hit Start and commit to focused work until the timer rings.</li>
							<li><strong>Take a short break</strong> — Rest for 5 minutes. Stretch, hydrate, or look away from the screen.</li>
							<li><strong>Repeat</strong> — After 4 pomodoros, take a longer 15–30 minute break to recharge.</li>
						</ol>

						<h3>Features</h3>
						<ul>
							<li><strong>Customizable durations</strong> — Adjust focus, short break, and long break times to suit your workflow.</li>
							<li><strong>Task tracking</strong> — Create tasks and track how many pomodoros each one takes.</li>
							<li><strong>Productivity analytics</strong> — View daily stats, focus minutes, and session history.</li>
							<li><strong>Browser notifications</strong> — Get notified when a session ends so you never miss a break.</li>
							<li><strong>Data export</strong> — Download your productivity data as JSON for personal analysis.</li>
							<li><strong>No sign-up required</strong> — Everything runs locally in your browser. Your data stays private.</li>
						</ul>
					</div>
				</details>
			</section>

			<!-- Collapsible FAQ Section -->
			<section class="faq-section">
				<h2 class="faq-title">Frequently Asked Questions</h2>
				{faqItems.map((item) => (
					<details class="faq-item">
						<summary class="faq-question">
							<span>{item.question}</span>
							<svg class="chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
						</summary>
						<p class="faq-answer">{item.answer}</p>
					</details>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.pomodoro-page-header {
		text-align: center;
		padding: 2em 0 1em;
	}
	.back-home {
		display: inline-block;
		margin-bottom: 1.5em;
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		transition: color var(--transition-fast);
	}
	.back-home:hover {
		color: var(--accent-cyan);
	}
	.pomodoro-page-header h1 {
		font-size: 2.5rem;
		margin-bottom: 0.25em;
	}
	.pomodoro-subtitle {
		color: var(--text-muted);
		font-size: 1.1rem;
		font-family: 'JetBrains Mono', monospace;
	}

	/* Noscript */
	.noscript-message {
		text-align: center;
		padding: 2em;
		margin: 2em auto;
		max-width: 500px;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		color: var(--text-secondary);
	}

	/* Learn More Accordion */
	.seo-section {
		max-width: 700px;
		margin: 3em auto 0;
		padding: 0 1em;
	}

	.learn-more-accordion {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		overflow: hidden;
	}

	.learn-more-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25em 1.5em;
		cursor: pointer;
		font-weight: 600;
		font-size: 1rem;
		color: var(--text-primary);
		list-style: none;
		transition: background 0.2s;
	}

	.learn-more-trigger::-webkit-details-marker {
		display: none;
	}

	.learn-more-trigger:hover {
		background: var(--bg-tertiary);
	}

	.learn-more-trigger .chevron {
		transition: transform 0.3s ease;
		flex-shrink: 0;
		color: var(--text-muted);
	}

	.learn-more-accordion[open] .learn-more-trigger .chevron {
		transform: rotate(180deg);
	}

	.learn-more-content {
		padding: 0 1.5em 1.5em;
		color: var(--text-secondary);
		line-height: 1.7;
	}

	.learn-more-content h2 {
		font-size: 1.25rem;
		color: var(--text-primary);
		margin-bottom: 0.75em;
	}

	.learn-more-content h3 {
		font-size: 1.05rem;
		color: var(--text-primary);
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}

	.learn-more-content p {
		margin-bottom: 1em;
	}

	.learn-more-content ul,
	.learn-more-content ol {
		padding-left: 1.5em;
		margin-bottom: 1em;
	}

	.learn-more-content li {
		margin-bottom: 0.5em;
	}

	/* FAQ Section */
	.faq-section {
		max-width: 700px;
		margin: 2em auto 4em;
		padding: 0 1em;
	}

	.faq-title {
		text-align: center;
		margin-bottom: 1.5em;
		font-size: 1.5rem;
	}

	.faq-item {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 10px;
		margin-bottom: 0.75em;
		overflow: hidden;
	}

	.faq-question {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1em 1.25em;
		cursor: pointer;
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--text-primary);
		list-style: none;
		transition: background 0.2s;
	}

	.faq-question::-webkit-details-marker {
		display: none;
	}

	.faq-question:hover {
		background: var(--bg-tertiary);
	}

	.faq-question .chevron {
		transition: transform 0.3s ease;
		flex-shrink: 0;
		color: var(--text-muted);
	}

	.faq-item[open] .faq-question .chevron {
		transform: rotate(180deg);
	}

	.faq-answer {
		padding: 0 1.25em 1.25em;
		color: var(--text-secondary);
		line-height: 1.7;
		font-size: 0.95rem;
	}

	@media (max-width: 640px) {
		.pomodoro-page-header h1 { font-size: 1.75rem; }
		.pomodoro-subtitle { font-size: 0.9rem; }
		.learn-more-trigger { padding: 1em 1.25em; font-size: 0.9rem; }
		.faq-question { padding: 0.875em 1em; font-size: 0.9rem; }
		.faq-answer { padding: 0 1em 1em; font-size: 0.9rem; }
	}

	/* Desktop Promo Section */
	.desktop-promo-section {
		max-width: 700px;
		margin: 3em auto 0;
		padding: 0 1em;
	}

	.promo-card {
		background: linear-gradient(135deg, var(--bg-secondary) 0%, rgba(18, 18, 26, 0.7) 100%);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 2.25em;
		position: relative;
		overflow: hidden;
		box-shadow: var(--shadow-lg);
		transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
	}

	.promo-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--accent-gradient);
	}

	.promo-card:hover {
		border-color: var(--accent-cyan);
		box-shadow: 0 0 25px rgba(6, 182, 212, 0.12);
	}

	.promo-tag {
		position: absolute;
		top: 1.5em;
		right: 1.5em;
		background: rgba(6, 182, 212, 0.1);
		color: var(--accent-cyan);
		border: 1px solid rgba(6, 182, 212, 0.2);
		padding: 0.25em 0.75em;
		border-radius: 20px;
		font-size: 0.75rem;
		font-family: 'JetBrains Mono', monospace;
		font-weight: 700;
		letter-spacing: 0.05em;
	}

	.promo-body h2 {
		font-size: 1.5rem;
		margin-bottom: 0.75em;
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.promo-desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
		margin-bottom: 1.75em;
		max-width: 90%;
	}

	.promo-features {
		display: flex;
		flex-direction: column;
		gap: 1em;
		margin-bottom: 2em;
	}

	.promo-feature {
		display: flex;
		align-items: flex-start;
		gap: 0.75em;
		font-size: 0.9rem;
		color: var(--text-secondary);
	}

	.feature-icon {
		color: var(--accent-cyan);
		flex-shrink: 0;
		margin-top: 0.2em;
	}

	.promo-actions {
		display: flex;
		align-items: center;
		gap: 1.5em;
		flex-wrap: wrap;
	}

	.btn-glow {
		box-shadow: 0 0 15px rgba(6, 182, 212, 0.15);
	}

	.btn-glow:hover {
		box-shadow: 0 0 25px rgba(6, 182, 212, 0.35);
	}

	.btn-secondary-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.btn-secondary-link:hover {
		color: var(--text-primary);
	}

	.btn-secondary-link .external-icon {
		transition: transform var(--transition-fast);
		margin-left: 0.2em;
	}

	.btn-secondary-link:hover .external-icon {
		transform: translate(2px, -2px);
	}

	@media (max-width: 640px) {
		.promo-card {
			padding: 1.75em;
		}
		.promo-tag {
			position: static;
			display: inline-block;
			margin-bottom: 1em;
		}
		.promo-desc {
			max-width: 100%;
		}
		.promo-actions {
			flex-direction: column;
			align-items: stretch;
			gap: 1em;
		}
		.btn-glow {
			justify-content: center;
		}
		.btn-secondary-link {
			justify-content: center;
		}
	}
</style>
