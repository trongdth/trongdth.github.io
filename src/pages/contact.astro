---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import { buildContactPageSchema, buildBreadcrumbSchema } from '../lib/schema-helpers';

const contactSchema = buildContactPageSchema();
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: 'Home', url: 'https://code4food.work' },
	{ name: 'Contact', url: 'https://code4food.work/contact' },
]);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="Get in touch with Trong Dinh — CTO & Technology Leader" />
		<SchemaOrg schema={contactSchema} />
		<SchemaOrg schema={breadcrumbSchema} />
	</head>
	<body>
		<Header />
		<main>
			<section class="contact-hero">
				<div class="contact-content">
					<h1>Get in <span class="glow-text">Touch</span></h1>
					<p class="lead">
						Have a question, a project in mind, or just want to say hi? I'd love to hear from you.
					</p>
				</div>
			</section>

			<section class="contact-methods">
				<div class="contact-card card">
					<h2>Email Me</h2>
					<p>The best way to reach me is via email. I try my best to reply within 24 hours.</p>
					<a href="mailto:trongdth@gmail.com" class="email-btn primary-btn">
						<svg viewBox="0 0 24 24" width="20" height="20">
							<path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
						</svg>
						trongdth@gmail.com
					</a>
				</div>
			</section>

			<section class="social-section">
				<h2>Connect on Social</h2>
				<p>You can also find me on these platforms to see what I'm currently working on:</p>
				
				<div class="social-grid">
					<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="social-card card">
						<svg viewBox="0 0 16 16" width="32" height="32">
							<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
						</svg>
						<h3>GitHub</h3>
						<span class="handle">@trongdth</span>
					</a>
					<a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener noreferrer" class="social-card card">
						<svg viewBox="0 0 24 24" width="32" height="32">
							<path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
						</svg>
						<h3>Twitter (X)</h3>
						<span class="handle">@trongdth</span>
					</a>
					<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="social-card card">
						<svg viewBox="0 0 24 24" width="32" height="32">
							<path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
						<h3>LinkedIn</h3>
						<span class="handle">in/trongdth</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 900px;
		width: 100%;
		overflow-x: hidden;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 3em;
		padding-bottom: 4em;
	}

	.contact-hero {
		text-align: center;
		padding: 4em 1em 0;
		width: 100%;
		box-sizing: border-box;
	}

	.contact-hero h1 {
		font-size: 3rem;
		margin-bottom: 0.5em;
	}

	.lead {
		font-size: 1.25rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.8;
	}

	.contact-methods {
		display: flex;
		justify-content: center;
		padding: 0 1em;
	}

	.contact-card {
		padding: 3em 2em;
		text-align: center;
		max-width: 600px;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5em;
	}

	.contact-card h2 {
		margin: 0;
	}

	.contact-card p {
		color: var(--text-secondary);
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.primary-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.75em 1.5em;
		background: var(--accent-cyan);
		color: var(--bg-primary);
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 1.1rem;
		transition: all var(--transition-fast);
	}

	.primary-btn:hover {
		background: var(--text-primary);
		color: var(--bg-primary);
		transform: translateY(-2px);
		box-shadow: var(--glow-cyan);
	}

	.social-section {
		padding: 0 1em;
		text-align: center;
	}

	.social-section h2 {
		margin-bottom: 0.5em;
	}

	.social-section > p {
		color: var(--text-muted);
		margin-bottom: 2em;
	}

	.social-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}

	.social-card {
		padding: 2em;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		color: inherit;
		transition: all var(--transition-fast);
	}

	.social-card:hover {
		transform: translateY(-4px);
		border-color: var(--accent-cyan);
		box-shadow: var(--glow-cyan);
	}

	.social-card svg {
		color: var(--accent-cyan);
		margin-bottom: 0.5em;
		transition: transform var(--transition-fast);
	}

	.social-card:hover svg {
		transform: scale(1.1);
	}

	.social-card h3 {
		margin: 0;
		font-size: 1.1rem;
		color: var(--text-primary);
	}

	.handle {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.contact-hero {
			padding: 2em 1em 0;
		}

		.contact-hero h1 {
			font-size: 2.25rem;
		}

		.lead {
			font-size: 1.1rem;
		}

		.contact-card {
			padding: 2em 1.5em;
		}

		.social-grid {
			grid-template-columns: 1fr;
			max-width: 320px;
			margin: 0 auto;
		}
	}
</style>
